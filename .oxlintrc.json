{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "options": { "typeAware": true, "typeCheck": true },
  "rules": { "typescript/unbound-method": "off" },
  "env": {
    "builtin": true
  }
}
